<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>⚡ CUENTOS QUE TE ATRAPARÁN ⚡</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Bangers&family=Fredoka+One&family=Nunito:wght@400;700;800&display=swap" rel="stylesheet">
<style>
  :root {
    --fire: #ff4500;
    --gold: #ffd700;
    --cosmic: #1a0533;
    --neon: #00ffcc;
    --pink: #ff2d78;
    --white: #f0ecff;
    --card-bg: rgba(45,15,94,0.85);
  }
  * { margin:0; padding:0; box-sizing:border-box; }
  body { background:var(--cosmic); font-family:'Nunito',sans-serif; color:var(--white); min-height:100vh; overflow-x:hidden; }

  #stars { position:fixed; top:0; left:0; width:100%; height:100%; pointer-events:none; z-index:0; overflow:hidden; }
  .star { position:absolute; background:white; border-radius:50%; animation:twinkle linear infinite; }
  @keyframes twinkle { 0%,100%{opacity:.2;transform:scale(1)} 50%{opacity:1;transform:scale(1.4)} }

  #portal { position:fixed; inset:0; z-index:100; background:var(--cosmic); display:flex; flex-direction:column; align-items:center; justify-content:center; gap:18px; transition:opacity .8s,transform .8s; }
  #portal.gone { opacity:0; pointer-events:none; transform:scale(1.2); }
  .ptitle { font-family:'Bangers',cursive; font-size:clamp(2.5rem,9vw,5rem); text-align:center; line-height:1; background:linear-gradient(135deg,#ffd700,#ff4500,#ff2d78); -webkit-background-clip:text; -webkit-text-fill-color:transparent; background-clip:text; animation:pglow 2s ease-in-out infinite; }
  @keyframes pglow { 0%,100%{filter:drop-shadow(0 0 18px rgba(255,100,0,.6))} 50%{filter:drop-shadow(0 0 38px rgba(255,215,0,1))} }
  .psub { font-family:'Fredoka One',cursive; font-size:clamp(1rem,3vw,1.4rem); color:var(--neon); text-align:center; letter-spacing:2px; }
  .emojis { font-size:2.5rem; display:flex; gap:14px; flex-wrap:wrap; justify-content:center; animation:float 3s ease-in-out infinite; }
  @keyframes float { 0%,100%{transform:translateY(0)} 50%{transform:translateY(-12px)} }
  .bbadge { background:rgba(0,255,204,.15); border:2px solid var(--neon); border-radius:30px; padding:8px 20px; font-size:.9rem; color:var(--neon); font-weight:800; }
  .benter { font-family:'Bangers',cursive; font-size:1.9rem; letter-spacing:3px; padding:18px 50px; border:none; border-radius:50px; background:linear-gradient(135deg,#ff4500,#ff2d78); color:white; cursor:pointer; transition:all .3s; animation:bpulse 2s ease-in-out infinite; }
  .benter:hover { transform:scale(1.08); }
  @keyframes bpulse { 0%,100%{box-shadow:0 0 28px rgba(255,69,0,.7)} 50%{box-shadow:0 0 48px rgba(255,215,0,.9)} }

  #app { position:relative; z-index:10; max-width:800px; margin:0 auto; padding:18px 15px 50px; display:none; }
  #app.on { display:block; }
  .atitle { font-family:'Bangers',cursive; font-size:clamp(2rem,7vw,3.2rem); text-align:center; background:linear-gradient(90deg,#ffd700,#ff4500,#ff2d78,#00ffcc); background-size:300%; -webkit-background-clip:text; -webkit-text-fill-color:transparent; background-clip:text; animation:rshift 4s linear infinite; padding:18px 0 10px; }
  @keyframes rshift { 0%{background-position:0%} 100%{background-position:300%} }

  .tstrip { background:linear-gradient(90deg,rgba(0,255,204,.08),rgba(255,45,120,.08)); border:1px solid rgba(0,255,204,.25); border-radius:13px; padding:11px 18px; display:flex; align-items:center; justify-content:space-between; margin:8px 0 18px; flex-wrap:wrap; gap:8px; }
  .tnum { font-family:'Bangers',cursive; font-size:1.6rem; color:var(--neon); letter-spacing:3px; }
  .tlabel { font-size:.78rem; color:rgba(240,236,255,.5); }
  .pbar { flex:1; min-width:110px; height:8px; background:rgba(255,255,255,.1); border-radius:10px; overflow:hidden; }
  .pfill { height:100%; background:linear-gradient(90deg,var(--neon),var(--gold)); border-radius:10px; width:0%; transition:width 1s linear; }
  .xplab { font-family:'Fredoka One',cursive; font-size:1rem; color:var(--gold); }

  .slabel { font-family:'Fredoka One',cursive; font-size:1.05rem; color:var(--neon); margin:18px 0 9px; letter-spacing:1px; text-transform:uppercase; }
  .cats { display:flex; flex-wrap:wrap; gap:9px; margin-bottom:6px; }
  .cbt { font-family:'Fredoka One',cursive; font-size:.9rem; padding:9px 17px; border-radius:30px; border:2px solid transparent; background:var(--card-bg); color:var(--white); cursor:pointer; transition:all .2s; display:flex; align-items:center; gap:6px; }
  .cbt:hover,.cbt.on { transform:scale(1.05); border-color:var(--gold); background:rgba(255,215,0,.12); color:var(--gold); }
  .moods { display:flex; flex-wrap:wrap; gap:8px; margin-bottom:15px; }
  .mbt { font-size:.82rem; padding:7px 14px; border-radius:20px; border:1.5px solid rgba(255,255,255,.2); background:transparent; color:var(--white); cursor:pointer; font-family:'Nunito',sans-serif; font-weight:700; transition:all .2s; }
  .mbt:hover,.mbt.on { border-color:var(--pink); background:rgba(255,45,120,.13); color:var(--pink); transform:scale(1.04); }

  .bgen { width:100%; font-family:'Bangers',cursive; font-size:1.8rem; letter-spacing:2px; padding:17px; border:none; border-radius:17px; background:linear-gradient(135deg,#ff4500,#ff2d78,#7b00ff); color:white; cursor:pointer; box-shadow:0 8px 28px rgba(255,69,0,.38); transition:all .3s; margin:15px 0; position:relative; overflow:hidden; }
  .bgen::after { content:''; position:absolute; inset:0; background:linear-gradient(135deg,transparent,rgba(255,255,255,.1),transparent); transform:translateX(-100%); transition:transform .5s; }
  .bgen:hover::after { transform:translateX(100%); }
  .bgen:hover { transform:translateY(-2px); box-shadow:0 14px 38px rgba(255,69,0,.58); }
  .bgen:disabled { opacity:.55; cursor:not-allowed; transform:none; }

  .lbox { text-align:center; padding:30px; display:none; }
  .lbox.on { display:block; }
  .lorb { width:68px; height:68px; margin:0 auto 15px; border-radius:50%; background:conic-gradient(#ff4500,#ffd700,#00ffcc,#ff2d78,#ff4500); animation:spin 1s linear infinite; }
  @keyframes spin { to{transform:rotate(360deg)} }
  .ltxt { font-family:'Fredoka One',cursive; font-size:1.15rem; color:var(--neon); animation:blink 1.2s ease-in-out infinite; }
  @keyframes blink { 0%,100%{opacity:1} 50%{opacity:.4} }

  .scard { background:var(--card-bg); border:1px solid rgba(255,215,0,.2); border-radius:22px; padding:26px 22px; display:none; box-shadow:0 20px 55px rgba(0,0,0,.5); backdrop-filter:blur(9px); animation:sup .5s ease; }
  .scard.on { display:block; }
  @keyframes sup { from{opacity:0;transform:translateY(28px)} to{opacity:1;transform:translateY(0)} }
  .stag { display:inline-block; background:rgba(255,45,120,.18); border:1px solid var(--pink); color:var(--pink); border-radius:20px; padding:3px 13px; font-size:.76rem; font-weight:800; letter-spacing:1px; margin-bottom:13px; text-transform:uppercase; }
  .stitle { font-family:'Bangers',cursive; font-size:clamp(1.6rem,5vw,2.4rem); background:linear-gradient(135deg,var(--gold),var(--fire)); -webkit-background-clip:text; -webkit-text-fill-color:transparent; background-clip:text; margin-bottom:14px; line-height:1.1; text-align:center; }
  .sbody { font-size:1.02rem; line-height:1.88; color:rgba(240,236,255,.9); margin-bottom:20px; }
  .sbody p { margin-bottom:13px; }
  .badges { display:flex; gap:9px; flex-wrap:wrap; margin:10px 0 6px; }
  .badge { font-size:.76rem; padding:4px 12px; border-radius:20px; font-weight:800; font-family:'Fredoka One',cursive; }
  .bf { background:rgba(255,69,0,.18); border:1px solid var(--fire); color:#ff9060; }
  .bn { background:rgba(0,255,204,.12); border:1px solid var(--neon); color:var(--neon); }
  .bg { background:rgba(255,215,0,.12); border:1px solid var(--gold); color:var(--gold); }

  .rbox { background:linear-gradient(135deg,rgba(123,0,255,.18),rgba(0,255,204,.08)); border:1.5px solid rgba(0,255,204,.28); border-radius:15px; padding:20px; margin-top:18px; }
  .rtitle { font-family:'Fredoka One',cursive; font-size:1.1rem; color:var(--neon); margin-bottom:13px; }
  .qcard { background:rgba(255,255,255,.04); border-left:3px solid var(--gold); border-radius:0 9px 9px 0; padding:11px 15px; margin-bottom:9px; font-size:.93rem; line-height:1.5; color:var(--white); cursor:pointer; transition:all .2s; }
  .qcard:hover { background:rgba(255,215,0,.07); transform:translateX(4px); border-left-color:var(--fire); }
  .aarea { margin-top:15px; display:none; }
  .aarea.on { display:block; }
  .aarea textarea { width:100%; background:rgba(255,255,255,.05); border:1.5px solid rgba(0,255,204,.28); border-radius:11px; color:var(--white); font-family:'Nunito',sans-serif; font-size:.92rem; padding:13px; resize:vertical; min-height:95px; outline:none; transition:border .2s; }
  .aarea textarea:focus { border-color:var(--neon); box-shadow:0 0 14px rgba(0,255,204,.2); }
  .aarea textarea::placeholder { color:rgba(255,255,255,.25); }
  .bsend { font-family:'Fredoka One',cursive; font-size:.97rem; padding:10px 23px; border:none; border-radius:30px; background:linear-gradient(90deg,var(--neon),#00bfa5); color:var(--cosmic); cursor:pointer; margin-top:10px; font-weight:800; transition:all .2s; }
  .bsend:hover { transform:scale(1.05); box-shadow:0 0 18px rgba(0,255,204,.45); }
  .airesp { background:rgba(0,255,204,.05); border:1px solid rgba(0,255,204,.18); border-radius:11px; padding:13px; margin-top:11px; font-size:.92rem; line-height:1.75; color:var(--white); display:none; white-space:pre-line; }
  .airesp.on { display:block; animation:sup .4s ease; }

  .bnext { width:100%; font-family:'Bangers',cursive; font-size:1.35rem; letter-spacing:2px; padding:14px; border:2px solid var(--gold); border-radius:15px; background:transparent; color:var(--gold); cursor:pointer; margin-top:13px; transition:all .3s; }
  .bnext:hover { background:rgba(255,215,0,.09); box-shadow:0 0 24px rgba(255,215,0,.3); transform:scale(1.01); }

  .toast { position:fixed; bottom:26px; left:50%; transform:translateX(-50%); background:linear-gradient(135deg,var(--fire),var(--pink)); color:white; font-family:'Bangers',cursive; font-size:1.35rem; letter-spacing:2px; padding:13px 30px; border-radius:50px; box-shadow:0 9px 38px rgba(255,69,0,.48); z-index:999; opacity:0; transition:opacity .4s; white-space:nowrap; pointer-events:none; }
  .toast.on { opacity:1; }

  @media(max-width:480px) {
    .sbody { font-size:.95rem; }
    .bgen { font-size:1.4rem; }
  }
</style>
</head>
<body>

<div id="stars"></div>

<!-- PORTAL -->
<div id="portal">
  <div class="emojis">🐉 🦕 🚀 👾 🌌 🔥</div>
  <div class="ptitle">⚡ CUENTOS<br>QUE TE<br>ATRAPARÁN ⚡</div>
  <div class="psub">¿ESTÁS LISTO PARA AVENTURAS ÉPICAS?</div>
  <div class="bbadge">🕐 Solo 5 minutos de pura magia</div>
  <button class="benter" onclick="enterApp()">¡ENTRAR AL UNIVERSO!</button>
</div>

<!-- APP -->
<div id="app">
  <div class="atitle">⚡ CUENTOS ÉPICOS ⚡</div>

  <div class="tstrip">
    <div><div class="tlabel">⏱ TIEMPO DE LECTURA</div><div class="tnum" id="tdisp">0:00</div></div>
    <div class="pbar"><div class="pfill" id="pfill"></div></div>
    <div class="xplab" id="xplab">⭐ 0 XP</div>
  </div>

  <div class="slabel">🎮 ¿Qué universo quieres hoy?</div>
  <div class="cats">
    <button class="cbt on" data-c="astronauta" onclick="selCat(this)">🚀 Astronautas</button>
    <button class="cbt" data-c="dragon" onclick="selCat(this)">🐉 Dragones</button>
    <button class="cbt" data-c="dinosaurio" onclick="selCat(this)">🦕 Dinosaurios</button>
    <button class="cbt" data-c="roblox" onclick="selCat(this)">👾 Roblox</button>
    <button class="cbt" data-c="monstruo" onclick="selCat(this)">👹 Monstruos</button>
    <button class="cbt" data-c="sorpresa" onclick="selCat(this)">✨ ¡Sorpréndeme!</button>
  </div>

  <div class="slabel">💥 ¿Qué tipo de historia?</div>
  <div class="moods">
    <button class="mbt on" data-m="apasionado" onclick="selMood(this)">🔥 Apasionada</button>
    <button class="mbt" data-m="reflexivo" onclick="selMood(this)">🧠 Reflexiva</button>
    <button class="mbt" data-m="dura" onclick="selMood(this)">⚔️ Épica dura</button>
    <button class="mbt" data-m="sensible" onclick="selMood(this)">💙 Sensible</button>
    <button class="mbt" data-m="misteriosa" onclick="selMood(this)">🌑 Misteriosa</button>
    <button class="mbt" data-m="comica" onclick="selMood(this)">😂 Cómica épica</button>
  </div>

  <button class="bgen" id="bgen" onclick="genStory()">🌌 ¡GENERAR MI CUENTO! 🌌</button>

  <div class="lbox" id="lbox">
    <div class="lorb"></div>
    <div class="ltxt" id="ltxt">Abriendo portales cósmicos...</div>
  </div>

  <div class="scard" id="scard">
    <div style="text-align:center"><div class="stag" id="gtag"></div></div>
    <div class="stitle" id="stitle"></div>
    <div class="badges" id="bdgs"></div>
    <div class="sbody" id="sbody"></div>
    <div class="rbox">
      <div class="rtitle">🌟 ¡Ahora es tu turno!</div>
      <div id="qlist"></div>
      <div class="aarea" id="aarea">
        <textarea id="atxt" placeholder="¡Escribe aquí tu respuesta, sin miedo! Tu imaginación no tiene límites..."></textarea>
        <button class="bsend" onclick="sendAns()">🚀 ¡Enviar mi respuesta!</button>
        <div class="ltxt" id="aiload" style="display:none;margin-top:9px">✨ Leyendo tu respuesta...</div>
        <div class="airesp" id="airesp"></div>
      </div>
    </div>
    <button class="bnext" onclick="genStory()">🔄 ¡Quiero otra aventura!</button>
  </div>
</div>

<div class="toast" id="toast">🏆 ¡5 MINUTOS COMPLETADOS! ¡ERES ÉPICO!</div>

<script>
// ── STARS ──────────────────────────────────────────────
const starsEl = document.getElementById('stars');
for (let i = 0; i < 110; i++) {
  const s = document.createElement('div');
  s.className = 'star';
  const sz = Math.random() * 2.2 + 0.5;
  s.style.cssText = `width:${sz}px;height:${sz}px;top:${Math.random()*100}%;left:${Math.random()*100}%;animation-duration:${Math.random()*3+2}s;animation-delay:${Math.random()*3}s;`;
  starsEl.appendChild(s);
}

// ── STATE ──────────────────────────────────────────────
let cat = 'astronauta', mood = 'apasionado', curQ = '', xp = 0;
let secs = 0, timerGo = false;
const GOAL = 300;
const lmsgs = [
  '🔥 Encendiendo motores estelares...',
  '🌌 Tejiendo dimensiones paralelas...',
  '⚡ Convocando personajes épicos...',
  '🧬 Mezclando magia con ciencia...',
  '🚀 Lanzando la nave a velocidad luz...',
  '🐉 Despertando al dragón dormido...',
  '👾 Generando código del universo...',
];
let lmi = 0;

// ── PORTAL ─────────────────────────────────────────────
function enterApp() {
  document.getElementById('portal').classList.add('gone');
  document.getElementById('app').classList.add('on');
  setTimeout(() => { document.getElementById('portal').style.display = 'none'; }, 900);
}

// ── SELECTORS ──────────────────────────────────────────
function selCat(b) {
  document.querySelectorAll('.cbt').forEach(x => x.classList.remove('on'));
  b.classList.add('on'); cat = b.dataset.c;
}
function selMood(b) {
  document.querySelectorAll('.mbt').forEach(x => x.classList.remove('on'));
  b.classList.add('on'); mood = b.dataset.m;
}

// ── TIMER ──────────────────────────────────────────────
function startTimer() {
  if (timerGo) return;
  timerGo = true;
  setInterval(() => {
    secs++; xp = Math.floor(secs * 0.5);
    const m = Math.floor(secs / 60), s = secs % 60;
    document.getElementById('tdisp').textContent = `${m}:${s.toString().padStart(2,'0')}`;
    document.getElementById('xplab').textContent = `⭐ ${xp} XP`;
    document.getElementById('pfill').style.width = Math.min((secs / GOAL) * 100, 100) + '%';
    if (secs === GOAL) {
      const t = document.getElementById('toast');
      t.classList.add('on');
      setTimeout(() => t.classList.remove('on'), 4500);
    }
  }, 1000);
}

// ── API CALL (via Netlify Function) ────────────────────
async function callClaude(messages, maxTokens = 1500) {
  const res = await fetch('/api/claude', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({
      model: 'claude-sonnet-4-20250514',
      max_tokens: maxTokens,
      messages,
    }),
  });
  if (!res.ok) {
    const err = await res.text();
    throw new Error(err);
  }
  const data = await res.json();
  return (data.content || []).map(i => i.text || '').join('').trim();
}

// ── GENERATE STORY ─────────────────────────────────────
const catN = {
  astronauta: 'astronautas y viajes espaciales',
  dragon: 'dragones y mundos de fantasía',
  dinosaurio: 'dinosaurios y mundos prehistóricos',
  roblox: 'mundos tipo Roblox y videojuegos',
  monstruo: 'monstruos épicos y criaturas salvajes',
  sorpresa: 'universo completamente sorpresivo y mezclado',
};
const moodN = {
  apasionado: 'apasionada e intensa que acelere el corazón',
  reflexivo: 'reflexiva y profunda que haga pensar',
  dura: 'épica y dura con acción extrema y peligro real',
  sensible: 'sensible y emotiva que toque el corazón',
  misteriosa: 'misteriosa y oscura con giros inesperados',
  comica: 'épicamente cómica llena de humor absurdo',
};

async function genStory() {
  const btn = document.getElementById('bgen');
  btn.disabled = true;
  document.getElementById('scard').classList.remove('on');
  document.getElementById('lbox').classList.add('on');
  document.getElementById('ltxt').textContent = lmsgs[lmi++ % lmsgs.length];

  const prompt = `Eres un narrador épico de cuentos para niños y jóvenes de 8-14 años.
Genera un cuento de ciencia ficción/fantasía ${moodN[mood]}, con temática de ${catN[cat]}.

REGLAS ABSOLUTAS:
- El título debe ser IMPACTANTE, que nadie pueda resistir leerlo (máx 10 palabras)
- El cuento debe tener mínimo 350 palabras, máximo 480 palabras
- Escríbelo con PASIÓN TOTAL: frases cortas que golpeen, descripciones vívidas, diálogos explosivos
- El personaje principal es un niño o joven que el lector quiera SER
- Debe tener un giro o momento que deje sin aliento
- El final NO lo resuelvas todo: que el lector quiera saber qué sigue
- Nombres inventados y únicos para los personajes
- Lenguaje claro, emocionante, como si fuera lo más importante del mundo

Al final genera exactamente 4 preguntas de reflexión APASIONADAS:
1. Cómo cambiaría el cuento
2. Quién sería él/ella en el cuento
3. Que describa con detalle a uno de los personajes
4. Que sueñe: qué haría si viviera esa aventura

RESPONDE ÚNICAMENTE CON JSON PURO SIN MARKDOWN:
{"titulo":"...","genero":"...","badges":["emoji palabra","emoji palabra","emoji palabra"],"cuento":"párrafos separados por \\n\\n","preguntas":["p1","p2","p3","p4"]}`;

  try {
    const raw = await callClaude([{ role: 'user', content: prompt }], 1500);
    const clean = raw.replace(/```json|```/g, '').trim();
    const story = JSON.parse(clean);
    renderStory(story);
    startTimer();
    document.getElementById('lbox').classList.remove('on');
  } catch (e) {
    console.error(e);
    document.getElementById('ltxt').textContent = '⚠️ Error al generar. ¡Intenta de nuevo!';
    document.getElementById('lbox').classList.remove('on');
  }
  btn.disabled = false;
}

// ── RENDER STORY ───────────────────────────────────────
function renderStory(s) {
  document.getElementById('gtag').textContent = s.genero || '⚡ Épico';
  document.getElementById('stitle').textContent = s.titulo;

  const bdgs = document.getElementById('bdgs');
  bdgs.innerHTML = '';
  (s.badges || []).forEach((b, i) => {
    const c = ['bf','bn','bg'][i % 3];
    bdgs.innerHTML += `<span class="badge ${c}">${b}</span>`;
  });

  const body = document.getElementById('sbody');
  body.innerHTML = '';
  (s.cuento || '').split('\n\n').forEach(p => {
    if (p.trim()) {
      const el = document.createElement('p');
      el.textContent = p.trim();
      body.appendChild(el);
    }
  });

  const ql = document.getElementById('qlist');
  ql.innerHTML = '';
  const em = ['🔥','👤','🎨','🌠'];
  (s.preguntas || []).forEach((q, i) => {
    const d = document.createElement('div');
    d.className = 'qcard';
    d.textContent = `${em[i] || '⭐'} ${q}`;
    d.onclick = () => openQ(q);
    ql.appendChild(d);
  });

  document.getElementById('aarea').classList.remove('on');
  document.getElementById('airesp').classList.remove('on');
  document.getElementById('atxt').value = '';
  document.getElementById('scard').classList.add('on');
  document.getElementById('scard').scrollIntoView({ behavior: 'smooth', block: 'start' });
}

// ── ANSWER ─────────────────────────────────────────────
function openQ(q) {
  curQ = q;
  document.getElementById('aarea').classList.add('on');
  document.getElementById('airesp').classList.remove('on');
  document.getElementById('atxt').focus();
  document.getElementById('aarea').scrollIntoView({ behavior: 'smooth', block: 'nearest' });
}

async function sendAns() {
  const txt = document.getElementById('atxt').value.trim();
  if (!txt) return;
  document.getElementById('aiload').style.display = 'block';
  document.getElementById('airesp').classList.remove('on');

  const prompt = `Eres un narrador épico y maestro de historias para niños de 8-14 años.
Un niño respondió esta pregunta sobre un cuento: "${curQ}"
Su respuesta fue: "${txt}"
Respóndele con PASIÓN TOTAL (4-5 oraciones):
- Celebra su respuesta de forma genuina y específica
- Amplía su idea con detalles épicos
- Dile algo que lo haga soñar más
- Invítalo a seguir imaginando
Habla como un amigo que ama las aventuras igual que él.`;

  try {
    const reply = await callClaude([{ role: 'user', content: prompt }], 300);
    document.getElementById('airesp').textContent = '✨ ' + reply;
    document.getElementById('airesp').classList.add('on');
    xp += 50;
    document.getElementById('xplab').textContent = `⭐ ${xp} XP`;
  } catch (e) {
    document.getElementById('airesp').textContent = '⚠️ No pude responder, ¡pero tu idea es genial!';
    document.getElementById('airesp').classList.add('on');
  }
  document.getElementById('aiload').style.display = 'none';
}
</script>
</body>
</html>
